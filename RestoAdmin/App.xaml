<Application x:Class="RestoAdmin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2193B0" Offset="0"/>
            <GradientStop Color="#6DD5ED" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2193B0" Offset="0"/>
            <GradientStop Color="#6DD5ED" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="BackgroundColor" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    </Application.Resources>
</Application>