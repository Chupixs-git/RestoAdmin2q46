<Window x:Class="RestoAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="АдминСтол - Система бронирования столиков" 
        Height="750" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" Padding="15" CornerRadius="0,0,15,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Ресторан АдминСтол" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Система бронирования столиков" FontSize="12" Foreground="#E0F7FA"/>
                    <TextBlock Text="Миссия: Создание комфортной атмосферы для каждого гостя"
                               FontSize="10" Foreground="#B2EBF2" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCurrentTime" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="текущая дата и время" FontSize="9" Foreground="#B2EBF2"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15" Background="{StaticResource CardBackground}" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" Padding="12" CornerRadius="15,15,0,0">
                        <TextBlock Text="Схема зала ресторана" FontWeight="Bold" Foreground="White" FontSize="14" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#FAFAFA">
                        <Canvas x:Name="HallCanvas" Width="900" Height="600" Background="#FAFAFA"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="15" Margin="15,0,0,0" Background="{StaticResource CardBackground}" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{StaticResource HeaderGradient}" Padding="12" CornerRadius="15,15,0,0">
                            <TextBlock Text="Бронирование столика" FontWeight="Bold" Foreground="White" FontSize="14" HorizontalAlignment="Center"/>
                        </Border>

                        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,10,10,5">
                            <StackPanel Margin="15">
                                <TextBlock Text="Дата и время бронирования" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="Дата:" FontSize="12" Margin="0,0,0,3"/>
                                        <DatePicker x:Name="DatePickerBooking" SelectedDate="{x:Static sys:DateTime.Today}" 
                                                    FontSize="13" Margin="0,0,0,10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="Время:" FontSize="12" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="ComboTime" SelectedIndex="6" FontSize="13" Margin="0,0,0,10">
                                            <ComboBoxItem Content="09:00"/>
                                            <ComboBoxItem Content="10:00"/>
                                            <ComboBoxItem Content="11:00"/>
                                            <ComboBoxItem Content="12:00"/>
                                            <ComboBoxItem Content="13:00"/>
                                            <ComboBoxItem Content="14:00"/>
                                            <ComboBoxItem Content="15:00"/>
                                            <ComboBoxItem Content="16:00"/>
                                            <ComboBoxItem Content="17:00"/>
                                            <ComboBoxItem Content="18:00"/>
                                            <ComboBoxItem Content="19:00"/>
                                            <ComboBoxItem Content="20:00"/>
                                            <ComboBoxItem Content="21:00"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Продолжительность (часов):" FontSize="12" Margin="0,5,0,3"/>
                                <ComboBox x:Name="ComboDuration" SelectedIndex="1" FontSize="13">
                                    <ComboBoxItem Content="1 час"/>
                                    <ComboBoxItem Content="2 часа"/>
                                    <ComboBoxItem Content="3 часа"/>
                                    <ComboBoxItem Content="4 часа"/>
                                    <ComboBoxItem Content="6 часа"/>
                                    <ComboBoxItem Content="8 часа"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,5">
                            <StackPanel Margin="15">
                                <TextBlock Text="Пожелания клиента" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkWindowView" Content="У окна" Margin="0,3" FontSize="13"/>
                                <CheckBox x:Name="ChkStageView" Content="У сцены" Margin="0,3" FontSize="13"/>
                                <CheckBox x:Name="ChkVipZone" Content="VIP-зона" Margin="0,3" FontSize="13"/>
                                <CheckBox x:Name="ChkQuietZone" Content="Тихая зона" Margin="0,3" FontSize="13"/>
                                <Button x:Name="BtnApplyFilter" Content="Подобрать столик" Margin="0,10,0,0" Padding="15,10" 
                                        Background="#2193B0" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnApplyFilter_Click"/>
                                <Button x:Name="BtnClearFilter" Content="Сбросить фильтр" Margin="0,5,0,0" Padding="15,10" 
                                        Background="#95A5A6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnClearFilter_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,5">
                            <StackPanel Margin="15">
                                <TextBlock Text="Данные клиента" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <TextBlock Text="Имя:" Margin="0,0,0,3" FontSize="12"/>
                                <TextBox x:Name="TxtCustomerName" Margin="0,0,0,10" Padding="8" FontSize="13" BorderBrush="#DDDDDD" BorderThickness="1"/>
                                <TextBlock Text="Телефон:" Margin="0,0,0,3" FontSize="12"/>
                                <TextBox x:Name="TxtCustomerPhone" Margin="0,0,0,10" Padding="8" FontSize="13" BorderBrush="#DDDDDD" BorderThickness="1"/>
                                <TextBlock Text="Email:" Margin="0,0,0,3" FontSize="12"/>
                                <TextBox x:Name="TxtCustomerEmail" Margin="0,0,0,10" Padding="8" FontSize="13" BorderBrush="#DDDDDD" BorderThickness="1"/>
                                <TextBlock Text="Количество персон:" Margin="0,0,0,3" FontSize="12"/>
                                <TextBox x:Name="TxtPersonsCount" Text="2" Margin="0,0,0,5" Padding="8" FontSize="13" BorderBrush="#DDDDDD" BorderThickness="1"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,5">
                            <StackPanel Margin="15">
                                <TextBlock Text="Дополнительные услуги" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkTableDecoration" Content="Украшение стола" Margin="0,3" FontSize="13"/>
                                <CheckBox x:Name="ChkFlowers" Content="Цветы на стол" Margin="0,3" FontSize="13"/>
                                <CheckBox x:Name="ChkCandles" Content="Свечи" Margin="0,3" FontSize="13"/>
                                <CheckBox x:Name="ChkBalloons" Content="Воздушные шары" Margin="0,3" FontSize="13"/>
                                <CheckBox x:Name="ChkLiveMusic" Content="Живая музыка" Margin="0,3" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,5">
                            <StackPanel Margin="15">
                                <TextBlock Text="Тип мероприятия" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <RadioButton x:Name="RbtnFamily" Content="Семейное торжество" Margin="0,3" FontSize="13" GroupName="EventType"/>
                                <RadioButton x:Name="RbtnRomantic" Content="Романтический ужин" Margin="0,3" FontSize="13" GroupName="EventType"/>
                                <RadioButton x:Name="RbtnCorporate" Content="Корпоратив" Margin="0,3" FontSize="13" GroupName="EventType"/>
                                <RadioButton x:Name="RbtnBanquet" Content="Банкет" Margin="0,3" FontSize="13" GroupName="EventType"/>
                                <TextBlock Text="Особые пожелания:" Margin="0,10,0,3" FontSize="12"/>
                                <TextBox x:Name="TxtSpecialRequests" Height="60" TextWrapping="Wrap" Padding="8" FontSize="13" BorderBrush="#DDDDDD" BorderThickness="1"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,5">
                            <StackPanel Margin="15">
                                <TextBlock Text="Выбранный столик" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <TextBlock x:Name="TxtSelectedTable" Text="Не выбран" Foreground="Gray" FontSize="13" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#2C3E50" CornerRadius="10" Margin="10,5" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Управление бронированиями" FontWeight="Bold" FontSize="13" Foreground="White" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnEditBooking" Grid.Column="0" Content="Редактировать бронь" Margin="5" Padding="12,10" 
                                            Background="#FF8C00" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnEditBooking_Click"/>
                                    <Button x:Name="BtnDeleteBooking" Grid.Column="1" Content="Удалить бронь" Margin="5" Padding="12,10" 
                                            Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnDeleteBooking_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,10,10,15">
                            <Button x:Name="BtnConfirmBooking" Content="Подтвердить бронирование" IsEnabled="False" Padding="15,10" 
                                    Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="5" Click="BtnConfirmBooking_Click"/>
                            <Button x:Name="BtnRefresh" Content="Обновить схему" Padding="15,10" 
                                    Background="#6DD5ED" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="5" Click="BtnRefresh_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#2193B0" Padding="8" CornerRadius="15,15,0,0">
            <TextBlock x:Name="TxtStatus" Text="Добро пожаловать в ресторан АдминСтол. Выберите столик на схеме зала." 
                       FontSize="11" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>